# Copy to .env and fill in. .env is auto-loaded at startup.

# Required: your Soniox API key (https://soniox.com -> dashboard).
SONIOX_API_KEY=your_key_here

# Optional: comma-separated language hints. Default: vi,en
TALK_LANGS=vi,en

# Optional: global toggle hotkey. Default: f7
# Examples: f7 | ctrl+alt+space | super+backslash | ctrl+shift+d
TALK_HOTKEY=f7

# Optional: live (incremental) paste. 1 = paste each chunk as you speak (default),
# 0 = paste the whole transcript once when you stop.
TALK_LIVE_PASTE=1

# Optional: desktop notifications for the final transcript/errors. 1 = on (default), 0 = off.
# (Recording state is shown by the tray icon, not a notification.)
TALK_NOTIFY=1

# Optional: how text is inserted into the focused field.
#   paste = clipboard + Ctrl+V (default, fast)
#   type  = synthesize keystrokes directly (more compatible with stubborn apps)
# If paste doesn't land in Slack/Chrome, try: TALK_PASTE_METHOD=type
TALK_PASTE_METHOD=paste

# Optional paste-timing tuning (milliseconds). Increase if pastes are flaky.
# TALK_PASTE_DELAY_BEFORE=150
# TALK_PASTE_DELAY_AFTER=120
# TALK_PASTE_SETTLE=350
# TALK_PASTE_RESTORE=1   # 0 = don't restore your previous clipboard
