# Copy to .env and fill in. .env is auto-loaded at startup.

# Required: your Soniox API key (https://soniox.com -> dashboard).
SONIOX_API_KEY=your_key_here

# Optional: Anthropic key — only needed for the Draft board (speech -> 3D ideas).
# https://claude.com
ANTHROPIC_API_KEY=

# Optional: comma-separated language hints (bias only). Default: vi
# Use vi,en if you mix English a lot.
TALK_LANGS=vi

# Optional: global toggle hotkey. Default: f7
# Examples: f7 | ctrl+alt+space | super+backslash | ctrl+shift+d
TALK_HOTKEY=f7

# Optional: assistant reply voice (Soniox TTS, 28 multilingual voices) + language.
# Voices: Maya, Daniel, Noah, Nina, Emma, Jack, Adrian, ... (see soniox.com/docs).
TALK_TTS_VOICE=Maya
TALK_TTS_LANG=vi

# Optional: how "insert to focus" types text into another app.
#   paste = clipboard + Ctrl+V (default, fast)
#   type  = synthesize keystrokes directly (more compatible with stubborn apps)
TALK_PASTE_METHOD=paste

# Optional paste-timing tuning (milliseconds), used by the type/paste worker.
# TALK_PASTE_DELAY_BEFORE=150
# TALK_PASTE_DELAY_AFTER=120
# TALK_PASTE_SETTLE=350
# TALK_PASTE_RESTORE=1   # 0 = don't restore your previous clipboard
